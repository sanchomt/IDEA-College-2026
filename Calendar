  {day:98,platforms:['Facebook','Instagram','LinkedIn'],theme:'Awareness',title:'Next intake — register your interest',copy:'Bridge post. Campaign ends, pipeline continues. Seed next intake. CTA to enquiry form.',type:'Graphic + Link'},
];

let activeFilter='all';
let currentView='week';
let calYear=2026,calMonth=5;

function getFiltered(){
  return posts.filter(p=>{
    if(activeFilter==='all')return true;
    if(['Facebook','Instagram','LinkedIn'].includes(activeFilter))return p.platforms.includes(activeFilter);
    return p.theme===activeFilter;
  });
}

function setView(v){
  currentView=v;
  document.getElementById('week-view').style.display=v==='week'?'block':'none';
  document.getElementById('cal-view').style.display=v==='cal'?'block':'none';
  document.getElementById('btn-week').classList.toggle('active',v==='week');
  document.getElementById('btn-cal').classList.toggle('active',v==='cal');
  if(v==='cal')renderCal();
}

function renderWeek(){
  const wrap=document.getElementById('week-view');
  wrap.innerHTML='';
  const fp=getFiltered();
  document.getElementById('s-total').textContent=fp.length;
  if(!fp.length){wrap.innerHTML='<div class="no-posts">No posts match this filter.</div>';return;}
  const weeks={};
  fp.forEach(p=>{
    const wn=Math.floor(p.day/7);
    if(!weeks[wn])weeks[wn]=[];
    weeks[wn].push({...p,date:addDays(START,p.day)});
  });
  Object.keys(weeks).sort((a,b)=>a-b).forEach((wn,wi)=>{
    const w=weeks[wn];
    const wStart=addDays(START,wn*7);
    const wEnd=addDays(wStart,6);
    const isOpen=wi<2;
    const wb=document.createElement('div');
    wb.className='week';
    wb.innerHTML=`<div class="whdr" onclick="toggleW(this)">
      <div><span class="wname">Week ${parseInt(wn)+1}</span><span class="wrange">${fmt(wStart)} – ${fmt(wEnd)}</span></div>
      <div class="wcnt">${w.length} post${w.length>1?'s':''}
        <svg class="chev${isOpen?' open':''}" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
    </div>
    <div class="wposts${isOpen?' open':''}">
      ${w.map(p=>`<div class="prow">
        <div class="dcell">${DAYS[p.date.getDay()]}<br>${p.date.getDate()} ${MS[p.date.getMonth()]}</div>
        <div class="plats">${p.platforms.map(pl=>`<span class="pb pb-${pl==='Facebook'?'fb':pl==='Instagram'?'ig':'li'}">${pl}</span>`).join('')}</div>
        <div>
          <div class="ptitle"><span class="tdot" style="background:${TC[p.theme]}"></span>${p.title}</div>
          <div class="pcopy">${p.copy}</div>
        </div>
        <div><span class="ttag">${p.type}</span></div>
      </div>`).join('')}
    </div>`;
    wrap.appendChild(wb);
  });
}

function toggleW(hdr){
  const posts=hdr.nextElementSibling;
  posts.classList.toggle('open');
  hdr.querySelector('.chev').classList.toggle('open');
}

function renderCal(){
  const fp=getFiltered();
  document.getElementById('s-total').textContent=fp.length;
  document.getElementById('cal-label').textContent=MONTHS[calMonth]+' '+calYear;
  const byDate={};
  fp.forEach(p=>{
    const d=addDays(START,p.day);
    const k=d.getFullYear()+'-'+d.getMonth()+'-'+d.getDate();
    if(!byDate[k])byDate[k]=[];
    byDate[k].push(p);
  });
  const grid=document.getElementById('cal-days');
  grid.innerHTML='';
  const first=new Date(calYear,calMonth,1);
  let dow=first.getDay();dow=dow===0?6:dow-1;
  const dim=new Date(calYear,calMonth+1,0).getDate();
  const today=new Date();
  for(let i=0;i<dow;i++){const c=document.createElement('div');c.className='ccell out';grid.appendChild(c);}
  for(let d=1;d<=dim;d++){
    const c=document.createElement('div');c.className='ccell';
    const k=calYear+'-'+calMonth+'-'+d;
    const dp=byDate[k]||[];
    const isToday=today.getFullYear()===calYear&&today.getMonth()===calMonth&&today.getDate()===d;
    const numDiv=document.createElement('div');
    numDiv.className='cnum'+(isToday?' today':dp.length?' active':'');
    numDiv.textContent=d;
    c.appendChild(numDiv);
    dp.forEach(p=>{
      const pill=document.createElement('div');
      pill.className='cpill';
      pill.style.background=TCB[p.theme];
      pill.style.color=TCT[p.theme];
      pill.textContent=p.title;
      pill.title=p.title;
      const dateObj=new Date(calYear,calMonth,d);
      pill.onclick=()=>showDetail(dateObj,dp);
      c.appendChild(pill);
    });
    grid.appendChild(c);
  }
  const total=dow+dim;
  const rem=(7-total%7)%7;
  for(let i=0;i<rem;i++){const c=document.createElement('div');c.className='ccell out';grid.appendChild(c);}
  document.getElementById('cal-detail').classList.remove('show');
  document.getElementById('cal-detail').innerHTML='';
}

function showDetail(dateObj,dp){
  const det=document.getElementById('cal-detail');
  det.classList.add('show');
  det.innerHTML=`<div class="cdetail-date">${DAYS[dateObj.getDay()]}, ${dateObj.getDate()} ${MONTHS[dateObj.getMonth()]} ${dateObj.getFullYear()}</div>`+
    dp.map(p=>`<div class="cpost">
      <div class="ptitle" style="margin-bottom:5px"><span class="tdot" style="background:${TC[p.theme]}"></span>${p.title}</div>
      <div style="font-size:12px;color:var(--muted);margin-bottom:6px;line-height:1.5">${p.copy}</div>
      <div style="display:flex;gap:4px;flex-wrap:wrap">
        ${p.platforms.map(pl=>`<span class="pb pb-${pl==='Facebook'?'fb':pl==='Instagram'?'ig':'li'}">${pl}</span>`).join('')}
        <span class="ttag">${p.type}</span>
      </div>
    </div>`).join('');
  det.scrollIntoView({behavior:'smooth',block:'nearest'});
}

function prevMonth(){calMonth--;if(calMonth<0){calMonth=11;calYear--;}renderCal();}
function nextMonth(){calMonth++;if(calMonth>11){calMonth=0;calYear++;}renderCal();}

document.getElementById('filters').addEventListener('click',e=>{
  const pill=e.target.closest('.pill');
  if(!pill)return;
  document.querySelectorAll('.pill').forEach(p=>p.classList.remove('active'));
  pill.classList.add('active');
  activeFilter=pill.dataset.f;
  renderWeek();
  if(currentView==='cal')renderCal();
});

renderWeek();
</script>
</body>
</html>
